{
  "name": "tirvea",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:live": "VERIFICATION_PROVIDER=stripe_identity ALLOW_LIVE_VERIFICATION=1 next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src prisma",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "format:check": "prettier --check src prisma",
    "face:preflight": "tsx scripts/face-preflight.ts",
    "face:calibrate": "tsx scripts/face-calibrate.ts",
    "calibration:enroll": "tsx scripts/calibration.ts enroll",
    "calibration:run": "tsx scripts/calibration.ts run",
    "calibration:clean": "tsx scripts/calibration.ts clean",
    "calibration:report": "tsx scripts/calibration.ts report",
    "ops:alert-test": "tsx scripts/ops-alert-test.ts",
    "face:rehearsal": "tsx scripts/face-rehearsal.ts",
    "trust:rehearsal": "tsx scripts/trust-rehearsal.ts",
    "test": "node scripts/run-tests.mjs",
    "perf:bundle": "node scripts/bundle-report.mjs",
    "perf:check": "node scripts/bundle-report.mjs --check",
    "perf:startup": "node scripts/measure-startup.mjs",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:integration:live": "node scripts/run-tests.mjs live",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:report": "playwright show-report",
    "db:validate": "prisma validate && prisma generate && git diff --exit-code --stat src/generated",
    "db:apply-migration": "tsx scripts/db-apply-migration.ts",
    "db:migrate:status": "node scripts/release/migrate-status.mjs",
    "db:migrate:deploy": "node scripts/release/migrate-deploy.mjs",
    "db:schema:verify": "node scripts/release/schema-verify.mjs",
    "release:preflight": "node scripts/release/preflight.mjs",
    "release:build": "npm run release:preflight && npm run build",
    "release:smoke": "node scripts/release/smoke.mjs",
    "release:production": "node scripts/release/production.mjs",
    "check:public-env": "node scripts/check-public-env.mjs",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run db:validate && npm run check:public-env && npm run test:unit && npm run build && npm run perf:check && npm run test:visual"
  },
  "dependencies": {
    "@aws-amplify/ui-react-liveness": "^3.6.7",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "aws-amplify": "^6.18.0",
    "blurhash": "^2.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "input-otp": "^1.4.2",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.16",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
