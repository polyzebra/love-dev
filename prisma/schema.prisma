// Tirvea - Prisma schema
// PostgreSQL (Supabase-compatible). Normalized, indexed for the hot paths:
// discovery feeds, match lookups, conversation timelines and admin queues.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  MODERATOR
  ADMIN
  // Owner tier: everything ADMIN has plus roles:assign + diagnostics:view
  // (src/lib/rbac.ts). Minted once via the admin bootstrap (docs/ADMIN-SETUP.md).
  SUPER_ADMIN
}

// Account status ladder (trust & safety). The enforcement semantics live in
// src/lib/services/trust-safety.ts (single source):
//   ACTIVE                -> full access
//   LIMITED               -> app access, cannot send likes/messages (expires
//                            with the backing AccountViolation)
//   PHOTO_REVIEW_REQUIRED -> app access, uploads blocked until photo
//                            verification / review clears
//   SUSPENDED             -> no app access; gate routes to /account-blocked;
//                            reversible, appealable
//   BANNED                -> terminal (bannedAt set alongside); appeal allowed
//   SHADOW_BANNED         -> legacy soft-hide (invisible to others)
//   DEACTIVATED           -> self-service deletion grace window
//   DELETED               -> tombstoned shell
enum AccountStatus {
  // PENDING = registration in progress. An app account is born PENDING and
  // is promoted to ACTIVE by the single activator (activateAccountIfComplete)
  // ONLY when the whole registration ladder completes. PENDING is NOT in the
  // discoverable/engageable sets, so a mid-registration account is invisible
  // and cannot swipe/chat/purchase (L7.3.8).
  PENDING
  ACTIVE
  LIMITED
  PHOTO_REVIEW_REQUIRED
  SUSPENDED
  BANNED
  SHADOW_BANNED
  DEACTIVATED
  DELETED
}

enum Gender {
  WOMAN
  MAN
  NON_BINARY
  OTHER
}

enum RelationshipGoal {
  LONG_TERM
  MARRIAGE_MINDED
  SHORT_TERM
  OPEN_TO_EITHER
  FRIENDSHIP
  FIGURING_OUT
}

enum LifestyleFrequency {
  NEVER
  RARELY
  SOCIALLY
  OFTEN
  PREFER_NOT_TO_SAY
}

enum ExerciseLevel {
  NEVER
  SOMETIMES
  REGULARLY
  DAILY
}

enum EducationLevel {
  SECONDARY
  UNDERGRADUATE
  POSTGRADUATE
  DOCTORATE
  TRADE_SCHOOL
  OTHER
}

enum ChildrenStatus {
  HAVE_AND_WANT_MORE
  HAVE_AND_DONT_WANT_MORE
  DONT_HAVE_WANT
  DONT_HAVE_DONT_WANT
  NOT_SURE
}

enum PetPreference {
  DOG
  CAT
  BOTH
  OTHER_PETS
  NONE
  ALLERGIC
}

enum VerificationType {
  EMAIL
  PHONE
  PHOTO
  IDENTITY
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum SwipeAction {
  LIKE
  PASS
  SUPER_LIKE
}

enum MatchStatus {
  ACTIVE
  UNMATCHED
  EXPIRED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum MessageType {
  TEXT
  IMAGE
  VOICE
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  SEEN
}

enum AttachmentType {
  IMAGE
  VOICE
}

enum ReportReason {
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  HARASSMENT
  SPAM
  SCAM
  UNDERAGE
  OFFLINE_BEHAVIOUR
  OTHER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  ACTION_TAKEN
  DISMISSED
}

// GOLD was named PREMIUM before the canonical Stripe lifecycle (2026-07-11);
// the enum value was renamed in place, existing rows carried over.
enum PlanTier {
  FREE
  PLUS
  GOLD
}

// Mirrors Stripe subscription statuses one-to-one, plus CHECKOUT_PENDING
// (a Checkout Session was created but Stripe has not confirmed anything
// yet - grants NOTHING). FREE is implicit: tier FREE + status ACTIVE.
// "Cancels later" is NOT a status - it is cancelAtPeriodEnd on an ACTIVE
// row, exactly how Stripe models it. EXPIRED is legacy (pre-lifecycle
// rows only); nothing writes it anymore.
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
  CHECKOUT_PENDING
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  REVOLUT
}

enum NotificationType {
  NEW_MATCH
  NEW_MESSAGE
  NEW_LIKE
  SUPER_LIKE
  PROFILE_VERIFIED
  SUBSCRIPTION
  SAFETY
  SYSTEM
}

// Transport a NotificationDelivery row targets. IN_APP is the Notification
// row itself (always written); the others are outbox work items.
enum DeliveryChannel {
  PUSH
  EMAIL
  SMS
  IN_APP
}

// Outbox lifecycle. SUPPRESSED = deliberately not sent (quiet hours would
// have deferred it, or the recipient was actively viewing the conversation);
// DEAD = gave up after max attempts. Honest states only - a row is never
// marked SENT unless the provider accepted it.
enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  DEAD
  SUPPRESSED
  // Email-only terminal states from the provider webhook: the recipient
  // mailbox rejected the message (BOUNCED) or the recipient marked it as
  // spam (COMPLAINED). Both feed the SuppressedEmail list.
  BOUNCED
  COMPLAINED
}

enum FirstMessageStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  DELETED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Lifecycle of the photo's binary assets (independent of human moderation):
// PROCESSING while variants are generated, ACTIVE once servable via the
// media proxy, REJECTED/DELETED keep the row for audit while hiding assets.
enum PhotoStatus {
  PROCESSING
  ACTIVE
  REJECTED
  DELETED
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

// Disposition of the app-verified phone's mirror into auth.users.phone.
// NULL = no verified phone. PENDING = app claim committed, auth write not
// yet confirmed. SYNCED = auth.users.phone equals phoneE164 (GoTrue stores
// it without the leading '+'). FAILED = admin write failed / service-role
// key absent - durable state the reconciliation service repairs; the
// business verification (phoneVerifiedAt) stays true regardless.
enum PhoneSyncStatus {
  PENDING
  SYNCED
  FAILED
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  // emailVerified timestamp doubles as the spec's "email verified" boolean
  emailVerified DateTime?
  // Legacy phone column - kept for compatibility; new code writes E.164 into
  // BOTH phone and phoneE164 (phoneE164 is the canonical column)
  phone         String?       @unique
  phoneVerified DateTime?
  name          String?
  image         String?
  role          Role          @default(USER)
  // Born PENDING; the canonical activator promotes to ACTIVE only when the
  // whole registration ladder completes (L7.3.8/L7.3.9). The DB CHECK
  // constraint forbids ACTIVE without registrationCompletedAt.
  status        AccountStatus @default(PENDING)

  // Phone verification (canonical) - E.164 format, one phone = one account.
  // The plain @unique is deliberately equivalent to a partial
  // "unique only when verified" index: phoneE164 is written in exactly ONE
  // place - the final-success transaction in src/lib/auth/phone-flow.ts,
  // atomically with phoneVerifiedAt. No code path writes it
  // pre-verification (the only other writers NULL it: identity teardown,
  // admin releasePhone), so an unverified row can never hold a claim and
  // block the number for someone else. Keep it that way.
  phoneE164          String?          @unique
  // No index on phoneCountryIso: written by the verify flows, read only by
  // primary key - never filtered/sorted on (verified 2026-07-10). Add one
  // only when a real query needs it.
  phoneCountryIso    String?
  phoneDialCode      String?
  phoneVerifiedAt    DateTime?
  // auth.users.phone sync state (see PhoneSyncStatus above). Written in the
  // same places as phoneE164: PENDING inside the final-success verify
  // transaction, then SYNCED/FAILED by the admin sync; releasePhone/teardown
  // NULL it with the number. No pendingPhoneE164 column: phoneE164 is only
  // ever written on approval, so a change-in-progress keeps the old number.
  phoneSyncStatus    PhoneSyncStatus?
  phoneSyncErrorCode String?
  phoneSyncUpdatedAt DateTime?

  // Auth hardening / risk
  authCompleted     Boolean   @default(false)
  riskScore         Int       @default(0)
  bannedAt          DateTime?
  banReason         String?
  lastLoginAt       DateTime?
  lastLoginIpHash   String?
  lastUserAgentHash String?
  previousIpHash    String?
  lastIpCountry     String?
  lastIpAsn         String?
  lastDeviceHash    String?
  deviceCount       Int       @default(0)

  // Trust & risk (0-100; reasons audited, never fabricated)
  scamScore     Int       @default(0)
  riskReason    String?
  riskUpdatedAt DateTime?

  // Trust ENGINE composite (src/lib/services/trust-engine.ts) - deliberately
  // separate columns from the LOGIN risk engine's riskScore above (risk.ts
  // owns that one; overwriting it here would be the split-brain the
  // verification.ts header warns about). The verification-derived trustScore
  // stays DERIVED (never stored) - see TRUST_WEIGHTS in verification.ts.
  // UserTrustStatus decision: User already carries status/riskScore/
  // scamScore/bannedAt, so per the audit-first doctrine these extend User
  // instead of adding a parallel 1:1 table.
  safetyRiskScore         Int                      @default(0)
  safetyRiskReasons       String?
  safetyRecommendedAction SafetyRecommendedAction?
  safetyRiskUpdatedAt     DateTime?

  // Age + legal consent (versioned; hashes, never raw IP/UA)
  ageConfirmedAt       DateTime?
  ageConfirmedIpHash   String?
  termsVersion         String?
  privacyVersion       String?
  communityVersion     String?
  consentAcceptedAt    DateTime?
  consentIpHash        String?
  consentUserAgentHash String?

  // Photo verification (provider abstraction; no biometrics stored)
  photoVerifiedAt           DateTime?
  photoVerificationProvider String?
  photoVerificationSession  String?
  // Face-badge suspension (profile-photo verification layer): the PUBLIC
  // badge is photoVerifiedAt && faceBadgeSuspendedAt == null. Suspension
  // never touches photoVerifiedAt - identity stays verified; only the
  // badge visibility is withheld while profile photos are in question.
  faceBadgeSuspendedAt      DateTime?
  // Epic 1 / F1: POSITIVE "Photo Verified" grant projection. INERT in this
  // phase - written by nothing, read by nothing (isPhotoVerified only). It
  // will be set by the worker (future epic) ONLY on a complete positive
  // proof: identity + bound reference + current cover MATCH + consent. NULL
  // for every existing user; the legacy badge (isPubliclyVerified) is unchanged.
  faceVerifiedAt            DateTime?

  // -----------------------------------------------------------------------
  // Gallery-integrity lockdown (L6.5). The blue Verified badge promises the
  // CURRENT gallery is the verified one - never a historical verification.
  // `galleryVersion` increments on every MATERIAL gallery change
  // (gallery-integrity.ts) SYNCHRONOUSLY inside the mutation transaction;
  // `verifiedGalleryVersion` is the snapshot stamped when verification passes.
  // The public badge requires verifiedGalleryVersion === galleryVersion, so a
  // material change turns the badge OFF instantly - no worker, no cache, no
  // webhook wait, and independent of the face-match provider being configured.
  // -----------------------------------------------------------------------
  galleryVersion                      Int       @default(0)
  verifiedGalleryVersion              Int?
  verifiedCoverPhotoId                String?
  verifiedGalleryHash                 String?
  // L6.6 immutable snapshot: the exact photo id set that was verified + when the
  // snapshot was stamped. The version gate is authoritative; these are the audit
  // record + defense-in-depth (verified photos still exist / cover still matches).
  verifiedPhotoIds                    String[]  @default([])
  verifiedGallerySnapshotAt           DateTime?
  photoVerificationInvalidatedAt      DateTime?
  photoVerificationInvalidationReason String?

  lastActiveAt      DateTime  @default(now())
  // onboardingDone doubles as the spec's "onboarding completed" boolean
  onboardingDone    Boolean   @default(false)
  marketingOptIn    Boolean   @default(false)
  deletionRequested DateTime?

  // Registration lifecycle (L7.3.8). registrationCompletedAt is the SINGLE
  // explicit "account activated" signal - stamped once, by the one activator
  // (activateAccountIfComplete), when the ladder finishes. onboardingCompletedAt
  // is the timestamp companion to onboardingDone. registrationStartedAt marks
  // when the app row was first provisioned. Completion is never inferred.
  // Set explicitly by the registration create paths + backfilled by migration;
  // no DB default (keeps migrations ≡ schema - see the drift gate).
  registrationStartedAt   DateTime?
  onboardingCompletedAt   DateTime?
  registrationCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  devices       Device[]
  profile       Profile?
  verifications Verification[]
  photos        Photo[]

  likesSent     Like[] @relation("LikesSent")
  likesReceived Like[] @relation("LikesReceived")

  firstMessagesSent     FirstMessage[] @relation("FirstMessagesSent")
  firstMessagesReceived FirstMessage[] @relation("FirstMessagesReceived")

  matchesAsA Match[] @relation("MatchUserA")
  matchesAsB Match[] @relation("MatchUserB")

  participants Participant[]
  messages     Message[]

  reportsMade     Report[] @relation("ReportsMade")
  reportsReceived Report[] @relation("ReportsReceived")
  blocksMade      Block[]  @relation("BlocksMade")
  blocksReceived  Block[]  @relation("BlocksReceived")

  subscription             Subscription?
  settings                 UserSettings?
  payments                 Payment[]
  notifications            Notification[]
  notificationDevices      NotificationDevice[]
  apiIdempotencyKeys       ApiIdempotencyKey[]
  conversationPresence     ConversationPresence[]
  explorePreferences       UserExplorePreference[]
  adminLogs                AdminLog[]                @relation("AdminActor")
  authEvents               AuthVerificationEvent[]
  moderationCases          ModerationCase[]          @relation("ModerationCases")
  violations               AccountViolation[]        @relation("AccountViolations")
  appeals                  Appeal[]                  @relation("Appeals")
  profilePhotoVerification ProfilePhotoVerification?
  livenessSessions         LivenessSession[]
  faceReferences           FaceReferenceRecord[]
  faceIdentityBindings     FaceIdentityBinding[]     @relation("FaceBindingSubject")
  faceBindingsReviewed     FaceIdentityBinding[]     @relation("FaceBindingReviewer")
  verificationAuditEvents  VerificationAuditEvent[]

  @@index([status, lastActiveAt])
  @@index([role])
}

model Device {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  userAgent   String?
  platform    String?
  ip          String?
  trusted     Boolean  @default(false)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([fingerprint])
}

// ---------------------------------------------------------------------------
// Profile & discovery
// ---------------------------------------------------------------------------

model Profile {
  id     String @id @default(cuid())
  userId String @unique

  displayName String
  bio         String?  @db.Text
  birthDate   DateTime
  gender      Gender
  heightCm    Int?

  relationshipGoal RelationshipGoal @default(FIGURING_OUT)

  // Location (coarse - city-level; exact coords never exposed to clients)
  city      String?
  region    String?
  country   String  @default("IE") // IE | GB
  latitude  Float?
  longitude Float?

  occupation String?
  employer   String?
  education  EducationLevel?
  school     String?

  languages String[] @default([])

  // Structured discovery tags (canonical values in src/lib/discovery/taxonomy.ts)
  availabilityTags String[] @default([])
  personalityTags  String[] @default([])
  communityTags    String[] @default([])

  smoking  LifestyleFrequency @default(PREFER_NOT_TO_SAY)
  drinking LifestyleFrequency @default(PREFER_NOT_TO_SAY)
  exercise ExerciseLevel?
  religion String?
  children ChildrenStatus?
  pets     PetPreference?

  // Discovery preferences
  interestedIn  Gender[]
  minAge        Int      @default(18)
  maxAge        Int      @default(99)
  maxDistanceKm Int      @default(80)

  // Visibility & state
  isVisible     Boolean   @default(true)
  isBoosted     Boolean   @default(false)
  boostedUntil  DateTime?
  completionPct Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests ProfileInterest[]
  prompts   ProfilePrompt[]

  @@index([isVisible, gender, country])
  @@index([latitude, longitude])
}

model Photo {
  id            String           @id @default(cuid())
  userId        String
  url           String // card-size variant (canonical 4:5); proxy path for new uploads
  thumbUrl      String? // 320x400 thumbnail variant (4:5)
  galleryUrl    String? // 720x900 gallery/grid variant (4:5)
  fullUrl       String? // 1800x2700 fullscreen-source variant (2:3, taller than 4:5)
  blurDataUrl   String? // base64 blur placeholder to avoid layout shift
  width         Int?
  height        Int?
  position      Int              @default(0)
  isCover       Boolean          @default(false)
  status        PhotoStatus      @default(PROCESSING)
  storagePath   String? // bucket-relative folder: users/{uid}/photos/{photoId}
  dominantColor String? // #rrggbb dominant colour of the source image
  faceDetected  Boolean? // reserved for the moderation phase
  facesCount    Int? // reserved for the moderation phase
  aiScore       Float? // reserved for the moderation phase
  mimeType      String? // mime type of the ORIGINAL upload (variants are always webp)
  sizeBytes     Int? // byte size of the ORIGINAL upload
  blurhash      String? // blurhash of the source image (4x3 components)
  moderation    ModerationStatus @default(PENDING)
  moderatedById String?
  moderatedAt   DateTime?
  // Bumped whenever the storage objects behind this photoId are rewritten
  // in place (e.g. a repair/reprocess). Part of the /api/media ETag so
  // clients holding the old immutable response refetch the new bytes.
  mediaVersion  Int              @default(0)
  createdAt     DateTime         @default(now())

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  moderationEvents  PhotoModerationEvent[]
  moderationResults PhotoModerationResult[]
  faceChecks        PhotoFaceCheck[]

  @@index([userId, position])
  @@index([moderation])
}

// Append-only audit trail for automated + human photo moderation decisions.
model PhotoModerationEvent {
  id        String   @id @default(cuid())
  photoId   String
  actorId   String? // null for automated decisions
  action    String // e.g. "auto-approved", "approved", "rejected"
  reason    String?
  aiScore   Float?
  createdAt DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([photoId, createdAt])
}

// Catalogue of selectable interests (seeded)
model Interest {
  id       String            @id @default(cuid())
  slug     String            @unique
  label    String
  category String // e.g. "Creativity", "Sports", "Going out"
  profiles ProfileInterest[]
}

model ProfileInterest {
  profileId  String
  interestId String

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([profileId, interestId])
  @@index([interestId])
}

// Verification records reference external providers (Veriff / Stripe Identity).
// Identity documents are NEVER stored - only provider references and status.
model Verification {
  id                String             @id @default(cuid())
  userId            String
  type              VerificationType
  status            VerificationStatus @default(PENDING)
  provider          String? // "veriff" | "stripe_identity" | "internal"
  providerSessionId String? // opaque reference on the provider side
  reviewedById      String?
  reviewNote        String?
  // L6.5 webhook safety (Phase H): the user's galleryVersion when this session
  // was started. A late/replayed approval restores the badge ONLY if the
  // gallery is unchanged since start (current galleryVersion === this value);
  // otherwise identity is stamped but the photo badge stays withheld pending
  // reverification. NULL = a session started before the lockdown (no pin).
  galleryVersionAtStart Int?
  // When `status` last CHANGED (webhook, reconciliation, admin review) -
  // the audit timestamp. updatedAt cannot serve: reconciliation throttle
  // writes (lastReconciledAt) bump it without any status change.
  statusChangedAt   DateTime?
  // Background-reconciliation throttle metadata: the atomic claim column
  // (updateMany where stale) that keeps provider polling to at most one
  // request per user per interval across all serverless instances.
  lastReconciledAt  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([status, type])
}

// ---------------------------------------------------------------------------
// Matching
// ---------------------------------------------------------------------------

model Like {
  id        String      @id @default(cuid())
  fromId    String
  toId      String
  action    SwipeAction
  seen      Boolean     @default(false)
  createdAt DateTime    @default(now())

  from User @relation("LikesSent", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("LikesReceived", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([toId, action, createdAt])
  @@index([fromId, createdAt])
}

// userAId < userBId is enforced in the service layer so a pair is unique.
model Match {
  id        String      @id @default(cuid())
  userAId   String
  userBId   String
  status    MatchStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  closedAt  DateTime?

  userA        User          @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB        User          @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  conversation Conversation?

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
}

// "Message before match" (Premium): a first message rides along with a Like
// and waits in the receiver's inbox. Only ONE PENDING row may exist per
// sender/receiver pair - status-dependent, so it cannot be a @@unique;
// the service checks inside the send transaction before creating.
model FirstMessage {
  id         String             @id @default(cuid())
  senderId   String
  receiverId String
  body       String             @db.Text
  status     FirstMessageStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  acceptedAt DateTime?
  declinedAt DateTime?
  expiresAt  DateTime?

  sender   User @relation("FirstMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FirstMessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, status])
  @@index([senderId, receiverId, status])
}

// ---------------------------------------------------------------------------
// Messaging
// ---------------------------------------------------------------------------

model Conversation {
  id            String             @id @default(cuid())
  matchId       String?            @unique
  status        ConversationStatus @default(ACTIVE)
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())

  match        Match?        @relation(fields: [matchId], references: [id], onDelete: SetNull)
  participants Participant[]
  messages     Message[]

  @@index([status, lastMessageAt])
}

model Participant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  isPinned       Boolean   @default(false)
  isArchived     Boolean   @default(false)
  isMuted        Boolean   @default(false)
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, isArchived, isPinned])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  type           MessageType   @default(TEXT)
  status         MessageStatus @default(SENT)
  body           String?       @db.Text
  replyToId      String?
  reactions      Json? // { "❤️": ["userId1"], ... }
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("MessageReply")
  attachments  Attachment[]
  reports      Report[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Attachment {
  id          String         @id @default(cuid())
  messageId   String
  type        AttachmentType
  url         String
  mimeType    String?
  sizeBytes   Int?
  width       Int?
  height      Int?
  durationSec Int?
  blurDataUrl String?
  createdAt   DateTime       @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ---------------------------------------------------------------------------
// Trust & safety
// ---------------------------------------------------------------------------

model Report {
  id           String       @id @default(cuid())
  reporterId   String
  reportedId   String
  messageId    String?
  reason       ReportReason
  details      String?      @db.Text
  status       ReportStatus @default(OPEN)
  resolvedById String?
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime     @default(now())

  reporter User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User     @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reportedId])
}

// --- Trust & safety enforcement (moderation cases / violations / appeals) --
// Naming: the raw spec's snake_case values map 1:1 onto these SCREAMING_CASE
// enum members (photo_mismatch -> PHOTO_MISMATCH, action_taken ->
// ACTION_TAKEN, ...). Prisma camelCase models per repo convention.

enum ModerationCaseType {
  PHOTO_MISMATCH
  STOLEN_IMAGES
  EXPLICIT_CONTENT
  MINOR_SAFETY
  IMPERSONATION
  SPAM
  HARASSMENT
  SCAM
  PAYMENT_ABUSE
  OTHER
}

enum ModerationCaseStatus {
  OPEN
  UNDER_REVIEW
  ACTION_TAKEN
  DISMISSED
  APPEALED
  REVERSED
}

enum CaseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseSource {
  AUTOMATED
  USER_REPORT
  ADMIN
  SYSTEM
}

enum PhotoModerationResultStatus {
  APPROVED
  REJECTED
  NEEDS_REVIEW
  FAILED
}

// What enforcement actually did to the account/photo (graduated ladder in
// trust-safety.ts). WARNING < PHOTO_REMOVED < UPLOAD_BLOCKED < LIMITED <
// SUSPENDED < BANNED.
enum EnforcementAction {
  WARNING
  PHOTO_REMOVED
  UPLOAD_BLOCKED
  LIMITED
  SUSPENDED
  BANNED
}

// Appeal lifecycle. SUBMITTED and PENDING_REVIEW are BOTH the
// "submitted, awaiting review" state (PENDING_REVIEW is the legacy alias -
// kept so no data/API rename breaks; new code writes SUBMITTED).
//   SUBMITTED/PENDING_REVIEW -> UNDER_REVIEW -> APPROVED/REJECTED
//   UNDER_REVIEW -> NEEDS_INFO -> (user responds) -> UNDER_REVIEW
//   NEEDS_INFO stale 14d -> EXPIRED (system)
//   any pre-decision state -> WITHDRAWN (user)
enum AppealStatus {
  SUBMITTED
  PENDING_REVIEW
  UNDER_REVIEW
  NEEDS_INFO
  APPROVED
  REJECTED
  EXPIRED
  WITHDRAWN
}

// Who wrote an AppealEvent timeline entry.
enum AppealActorRole {
  USER
  STAFF
  SYSTEM
}

enum BannedCredentialKind {
  PHONE
  DEVICE
}

// Trust-engine recommendation (server-side only - NEVER exposed to users).
enum SafetyRecommendedAction {
  NO_ACTION
  SHOW_WARNING
  REQUIRE_PHOTO_VERIFICATION
  HIDE_PROFILE
  LIMIT_MESSAGING
  SUSPEND_ACCOUNT
  BAN_ACCOUNT
  SEND_TO_MANUAL_REVIEW
}

// One investigation about one user. Dedupe rule (service-enforced, like
// FirstMessage's "one PENDING per pair" - status-dependent, so it cannot be
// a @@unique): at most one OPEN/UNDER_REVIEW case per (userId, caseType);
// new automated signals append to the open case's evidence instead.
model ModerationCase {
  id             String               @id @default(cuid())
  userId         String
  caseType       ModerationCaseType
  status         ModerationCaseStatus @default(OPEN)
  severity       CaseSeverity
  source         CaseSource
  /**
   * 0-1 confidence of the triggering signal; null for human-sourced cases.
   */
  confidence     Float?
  summary        String
  /**
   * PII-stripped structured evidence: photo ids, score snapshots, report ids.
   */
  evidence       Json?
  photoId        String?
  reportId       String?
  reviewedById   String?
  reviewedAt     DateTime?
  decisionReason String?

  // --- SLA / queue workflow (policy constants in trust-safety.ts) ---------
  // priority defaults to the severity at creation (service-set; escalation
  // may bump it above severity later - severity itself never changes).
  priority        CaseSeverity @default(MEDIUM)
  // Deadline derived from priority at creation: critical 4h, high 24h,
  // medium 72h, low 7d. Escalation does NOT move an existing deadline.
  slaDueAt        DateTime?
  assignedToId    String?
  // Stamped once - the first staff workflow action on the case.
  firstResponseAt DateTime?
  // Stamped when the case reaches a terminal decision (ACTION_TAKEN/
  // DISMISSED/REVERSED); cleared if it is reopened.
  resolvedAt      DateTime?
  lastActivityAt  DateTime     @default(now())
  // Set when the overdue sweep escalated this case (one bump only).
  escalatedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User               @relation("ModerationCases", fields: [userId], references: [id], onDelete: Cascade)
  violations AccountViolation[]

  @@index([userId, status])
  @@index([status, severity, createdAt])
  @@index([status, slaDueAt])
  @@index([assignedToId, status])
}

// Automated moderation provider output for one photo - scores only, PII
// stripped. NO biometric vectors, face templates or embeddings, ever;
// rawProviderReference is an opaque id on the provider's side.
model PhotoModerationResult {
  id                   String                      @id @default(cuid())
  photoId              String
  provider             String
  resultStatus         PhotoModerationResultStatus
  detectedLabels       Json                        @default("[]")
  faceCount            Int?
  adultScore           Float?
  violenceScore        Float?
  minorRiskScore       Float?
  aiGeneratedScore     Float?
  duplicateMatchScore  Float?
  reverseImageRisk     Float?
  confidence           Float?
  rawProviderReference String?
  createdAt            DateTime                    @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([photoId, createdAt])
}

// One enforcement action applied to one account. userVisibleReason is the
// ONLY reason field surfaced to the user (calm, legally-safe copy);
// internalReason and confidence stay staff-side.
model AccountViolation {
  id                String             @id @default(cuid())
  userId            String
  violationType     ModerationCaseType
  actionTaken       EnforcementAction
  description       String
  userVisibleReason String
  internalReason    String?
  /**
   * null = does not expire (warnings, suspensions pending review, bans).
   */
  expiresAt         DateTime?
  appealAllowed     Boolean            @default(true)
  /**
   * Signal-ownership marker (risk registry): violations created by the
   * face-verification layer set "face_verification" - trust-engine
   * EXCLUDES them from its violation signal because the risk engine
   * already scores the underlying face outcome (double-count fix, PRR
   * TD-2). Stable code value - never display text.
   */
  source            String?
  /**
   * Set when an approved appeal reversed this violation.
   */
  reversedAt        DateTime?
  moderationCaseId  String?
  /**
   * The photo the action was about, when there is one. Deliberately on the
   * violation itself (not only the case): cases DEDUPE per user+type, so a
   * merged case's photoId cannot drive an accurate reversal.
   */
  photoId           String?
  createdAt         DateTime           @default(now())

  user           User            @relation("AccountViolations", fields: [userId], references: [id], onDelete: Cascade)
  moderationCase ModerationCase? @relation(fields: [moderationCaseId], references: [id], onDelete: SetNull)
  appeals        Appeal[]

  @@index([userId, createdAt])
  @@index([userId, actionTaken, expiresAt])
}

// One user appeal against one violation. "One open appeal per violation" is
// status-dependent (a REJECTED appeal on a still-active ban may not retry,
// but an APPROVED one closes the story) - enforced in appeals.ts inside the
// submit transaction, same pattern as FirstMessage.
model Appeal {
  id                   String       @id @default(cuid())
  violationId          String
  userId               String
  status               AppealStatus @default(SUBMITTED)
  appealText           String       @db.Text
  /**
   * STAFF-ONLY. Never selected into any user read model (asserted in tests).
   */
  adminNotes           String?
  reviewedById         String?
  reviewedAt           DateTime?
  /**
   * Set when staff moved the appeal to NEEDS_INFO; drives the 14-day
   * auto-expiry sweep. Cleared when the user responds.
   */
  needsInfoRequestedAt DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  violation AccountViolation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  user      User             @relation("Appeals", fields: [userId], references: [id], onDelete: Cascade)
  events    AppealEvent[]

  @@index([violationId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([status, needsInfoRequestedAt])
}

// Append-only appeal timeline (message thread + state changes). `note` is
// USER-VISIBLE copy (the needs-info question, the user's reply, decision
// notices) - staff-private commentary belongs in Appeal.adminNotes, never
// here.
model AppealEvent {
  id        String          @id @default(cuid())
  appealId  String
  /**
   * submitted | under_review | needs_info_requested | user_responded |
   * approved | rejected | withdrawn | expired
   */
  type      String
  actorRole AppealActorRole
  note      String?         @db.Text
  createdAt DateTime        @default(now())

  appeal Appeal @relation(fields: [appealId], references: [id], onDelete: Cascade)

  @@index([appealId, createdAt])
}

// Ban-evasion blocklist - legally-acceptable signals only: the verified
// E.164 number and the salted device hash (see device.ts - never a raw
// identifier). Checked at phone login/verification and device registration.
// Rows are removed when a ban is reversed (appeal approved / admin unban).
model BannedCredential {
  id           String               @id @default(cuid())
  kind         BannedCredentialKind
  /**
   * E.164 phone (kind PHONE) or salted device hash (kind DEVICE).
   */
  value        String
  reason       String?
  sourceUserId String?
  createdAt    DateTime             @default(now())
  expiresAt    DateTime?

  @@unique([kind, value])
  @@index([sourceUserId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

// One row per user; the SINGLE server-side source of truth for plan and
// entitlements. Every field below is written only from verified Stripe
// state (webhook or authenticated server-side reconciliation) - never
// from anything the browser sends. providerCustomerId is UNIQUE: one
// Stripe customer maps to exactly one user, ever.
model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  tier               PlanTier           @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  provider           PaymentProvider    @default(STRIPE)
  providerCustomerId String?            @unique
  providerSubId      String?            @unique
  /// Stripe price id currently subscribed to - tier is derived from this via the trusted env price map.
  stripePriceId      String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  canceledAt         DateTime?
  trialStart         DateTime?
  trialEnd           DateTime?
  /// Latest Checkout Session created for this user (CHECKOUT_PENDING bookkeeping).
  checkoutSessionId  String?
  /// Stripe event id that produced the last sync - diagnostics only (sync always refetches latest).
  lastStripeEventId  String?
  syncedAt           DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, currentPeriodEnd])
}

// Durable webhook idempotency ledger: one row per Stripe event id.
// processedAt stays NULL until the handler finished successfully, so a
// crash mid-processing lets the Stripe retry reprocess the event, while
// an already-processed duplicate delivery is acknowledged without work.
model StripeEvent {
  id          String    @id
  type        String
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([type, receivedAt])
}

model Payment {
  id                String          @id @default(cuid())
  userId            String
  provider          PaymentProvider @default(STRIPE)
  providerPaymentId String?         @unique
  amountCents       Int
  currency          String          @default("eur")
  status            PaymentStatus   @default(PENDING)
  description       String?
  invoiceUrl        String?
  receiptUrl        String?
  createdAt         DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Platform
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, readAt, createdAt])
}

// Delivery transport for one registered device (Phase 0H). WEB_PUSH is
// live; APNS/FCM registration + storage + fan-out are ready and their
// adapters answer transport_not_configured until native credentials ship.
enum NotificationTransport {
  WEB_PUSH
  APNS
  FCM
}

// One registered notification target per row: a browser push endpoint
// (WEB_PUSH: endpoint + p256dh/auth public material) or an opaque device
// token (APNS/FCM). Tokens/endpoints are delivery credentials: never log
// them whole, never return them whole from routes. The VAPID/APNs/FCM
// PRIVATE keys are env-only and must never be stored in the DB. Rows are
// invalidated (invalidatedAt + enabled=false), never deleted, so device
// history stays auditable. Mapped onto the original PushSubscription
// table - the migration is purely additive.
model NotificationDevice {
  id             String                @id @default(cuid())
  userId         String
  transport      NotificationTransport @default(WEB_PUSH)
  // WEB_PUSH only - the push service capability URL + encryption keys.
  endpoint       String?               @unique @db.Text
  p256dh         String?
  auth           String?
  // APNS/FCM only - the opaque device/registration token.
  token          String?               @unique @db.Text
  userAgent      String?
  platform       String?
  browser        String?
  deviceLabel    String?
  installationId String?
  appVersion     String?
  environment    String                @default("production")
  enabled        Boolean               @default(true)
  lastSeenAt     DateTime              @default(now())
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  failureCount   Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  invalidatedAt  DateTime?             @map("revokedAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@map("PushSubscription")
}

// Per-channel outbox for a Notification. IN_APP rows are written SENT
// immediately (the Notification row IS the in-app delivery); PUSH rows are
// claimed by processPendingPush with exponential backoff via nextAttemptAt;
// EMAIL/SMS rows exist for safety/account notices and go DEAD with
// errorCode "not_configured" until a provider ships - no fake sends.
model NotificationDelivery {
  id                String          @id @default(cuid())
  notificationId    String
  channel           DeliveryChannel
  status            DeliveryStatus  @default(PENDING)
  provider          String?
  providerMessageId String?
  attempt           Int             @default(0)
  nextAttemptAt     DateTime?
  errorCode         String?
  errorMessage      String?
  idempotencyKey    String          @unique
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime        @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, channel])
  @@index([status, createdAt])
  // Email provider webhooks (delivered/bounced/complained) look rows up by
  // the provider's message id.
  @@index([providerMessageId])
}

// Email suppression list - addresses we must NOT send to any more (hard
// bounce or spam complaint reported by the provider webhook). Checked by
// the email outbox worker before every send; rows are only removed by a
// deliberate admin action, never automatically.
model SuppressedEmail {
  id              String   @id @default(cuid())
  email           String   @unique
  /**
   * "hard_bounce" | "complaint" | "manual"
   */
  reason          String
  /**
   * Provider message id of the delivery that triggered the suppression.
   */
  sourceMessageId String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

// Rolling health of one external provider (moderation/email). Written by
// the fallback chain on every attempt; read by the admin dashboard. A row
// per provider name - consecutiveFailures resets to 0 on success.
model ProviderHealth {
  id                  String    @id @default(cuid())
  provider            String    @unique
  consecutiveFailures Int       @default(0)
  totalFailures       Int       @default(0)
  totalSuccesses      Int       @default(0)
  lastError           String?
  lastErrorAt         DateTime?
  lastSuccessAt       DateTime?
  updatedAt           DateTime  @updatedAt
}

// Heartbeat of "user X is looking at conversation Y right now" - used to
// suppress push for messages the recipient is already reading. Client pings
// POST /api/presence/heartbeat every ~10s; a row younger than 30s counts
// as present.
model ConversationPresence {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  lastSeenAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId, lastSeenAt])
}

model AdminLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String // e.g. "user.suspend", "report.resolve", "flag.update"
  targetType String? // "user" | "report" | "photo" | ...
  targetId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  actor User @relation("AdminActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  // Optional percentage rollout (0-100) and audience rules
  rollout     Int      @default(100)
  rules       Json?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Explore - data-driven discovery categories
// ---------------------------------------------------------------------------

enum ExploreGroup {
  LIFESTYLE
  INTERESTS
  GOALS
  TODAY
  PERSONALITY
  COMMUNITIES
}

model ExploreCategory {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  description  String?
  group        ExploreGroup
  iconKey      String // maps to a 3D visual; real assets swap in via imageUrl
  imageUrl     String?
  gradientFrom String       @default("#fb7185")
  gradientTo   String       @default("#be123c")
  // Predicate for matching profiles, e.g.
  // {"kind":"interests","values":["coffee-dates"]} | {"kind":"goal","values":["LONG_TERM"]}
  // {"kind":"country","values":["IE"]} | {"kind":"recentlyActive"} | {"kind":"preference"}
  matcher      Json?
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  preferences UserExplorePreference[]

  @@index([isActive, group, sortOrder])
}

model UserExplorePreference {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  weight     Int      @default(1)
  createdAt  DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExploreCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([categoryId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  data      Json?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}

// Identity blocklist - emails/providers that may never authenticate again.
model BlockedIdentity {
  id        String    @id @default(cuid())
  email     String    @unique
  provider  String? // google | apple | email | null = all
  reason    String?
  blockedAt DateTime  @default(now())
  expiresAt DateTime?
  createdBy String?

  @@index([email])
}

// Append-only auth audit trail: OTP sends/verifies, failures, risk events.
// Also the data source for the DB-backed sliding-window rate limiter, so
// events are recorded even when the request is rejected.
model AuthVerificationEvent {
  id            String   @id @default(cuid())
  userId        String?
  email         String?
  phoneE164     String?
  type          String // email_otp_send | email_otp_verify | otp_verify_fail | phone_otp_send | ...
  ipHash        String?
  userAgentHash String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([phoneE164, createdAt])
  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
}

// Human voice on profiles - answers to curated prompts. These power
// Discover story cards, chat openers and the match moment.
model ProfilePrompt {
  id        String   @id @default(cuid())
  profileId String
  promptKey String // canonical key from src/config/prompts.ts
  answer    String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, promptKey])
  @@index([profileId, sortOrder])
}

enum AppearanceMode {
  SYSTEM
  LIGHT
  DARK
}

// Per-user notification + appearance preferences. This model IS the spec's
// "NotificationPreference" - one row per user, per-type toggles per channel:
//   push:  pushNewMatches/pushMessages/pushMessageLikes/pushSuperLikes/
//          pushDailyPicks/pushOffers/safetyPush/accountPush
//   email: emailNewMatches/emailMessages/emailPromotions/safetyEmail/accountEmail
//   sms:   smsEnabled (master) + safetySms/accountSms
// Quiet hours are minutes-since-midnight in the user's own timezone
// (IANA name in `timezone`); an overnight range (start > end) wraps.
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique

  emailNewMatches  Boolean @default(true)
  emailMessages    Boolean @default(true)
  emailPromotions  Boolean @default(false)
  pushNewMatches   Boolean @default(true)
  pushMessages     Boolean @default(true)
  pushMessageLikes Boolean @default(true)
  pushSuperLikes   Boolean @default(true)
  pushDailyPicks   Boolean @default(false)
  pushOffers       Boolean @default(false)
  smsEnabled       Boolean @default(false)
  // Native-only preferences: in-app notification sounds/haptics belong to
  // the future native (Capacitor) shell - the web app neither reads nor
  // writes them and the OS decides push sound/vibration on every platform.
  // Kept (not dropped) so a native client can adopt them without a
  // migration. See docs/NOTIFICATIONS-NATIVE.md.
  inAppVibrations  Boolean @default(true)
  inAppSounds      Boolean @default(false)

  // Safety (SAFETY) + account (PROFILE_VERIFIED/SUBSCRIPTION/SYSTEM)
  // notices per channel. These default ON - they are not marketing.
  safetyPush   Boolean @default(true)
  accountPush  Boolean @default(true)
  safetyEmail  Boolean @default(true)
  accountEmail Boolean @default(true)
  safetySms    Boolean @default(true)
  accountSms   Boolean @default(true)

  // Quiet hours: minutes since local midnight, 0-1439. Push is deferred
  // (not dropped) while inside the window; safety notices ignore it.
  quietHoursEnabled Boolean @default(false)
  quietHoursStart   Int?
  quietHoursEnd     Int?
  timezone          String?

  appearance AppearanceMode @default(SYSTEM)
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Server-side idempotency for unsafe mutations (Phase 0D, v1 contract:
// docs/API-CONTRACT.md). One row per (user, endpoint scope, client key);
// a replayed key returns the stored response instead of re-executing.
// Only non-5xx responses are stored, so a failed attempt may be retried
// with the same key. Rows older than 24h are prunable (createdAt index).
model ApiIdempotencyKey {
  id        String   @id @default(cuid())
  userId    String
  /// Endpoint scope, e.g. "messages:send:<conversationId>".
  scope     String
  /// Client-generated key (Idempotency-Key header).
  key       String
  status    Int
  response  Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, key])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Profile-photo verification (face match) - SEPARATE from identity
// verification. Stripe verifies the document+selfie (Verification type
// PHOTO + User.photoVerifiedAt, canonical and unchanged); this layer
// verifies that the PROFILE GALLERY belongs to that verified person.
// PRIVACY: no embeddings/templates/biometric vectors are ever stored -
// only the provider's opaque reference id and derived classifications.
// ---------------------------------------------------------------------------

enum ProfilePhotoVerificationStatus {
  LIVENESS_REQUIRED // identity verified, but no valid liveness-derived reference yet - user action required (C-2)
  QUEUED // enqueued, waiting for the worker/cron
  CLAIMED // a worker holds the lease (H-2 mutual exclusion)
  CHECKING // face comparisons in flight
  AUTO_VERIFIED // cover matched, no high-risk gallery mismatches
  MANUAL_REVIEW // uncertain cover / mixed results - human decides
  REJECTED // confident cover mismatch or no valid profile face
  SUSPENDED // aggregate risk or staff action - badge withheld
}

enum FaceBadgeStatus {
  NONE // no face verification yet (or feature off)
  ACTIVE // badge visible
  REVIEWING // temporarily reviewing (new cover/photos in check)
  SUSPENDED // withheld pending review/re-challenge
}

enum FaceCheckClassification {
  OWNER_MATCHED // verified user recognised
  NO_FACE // no face visible (lifestyle/pet/travel - allowed)
  GROUP_PHOTO // several people, owner identified among them
  OTHER_PERSON_ONLY // face(s) present but owner not found
  UNCERTAIN // insufficient quality/confidence
  MANIPULATION_RISK // possible AI generation / manipulation / screenshot
}

/**
 * Reference lifecycle (Phase 3): a reference is usable ONLY while ACTIVE
 * or EXPIRING - runs refuse EXPIRED/REVOKED/DELETED and require
 * re-enrolment (rotation).
 */
enum FaceReferenceStatus {
  ACTIVE
  EXPIRING // within the renewal window - still valid, rotation nudged
  EXPIRED // past expiresAt - NEVER reused
  REVOKED // fraud investigation / policy - never reused
  DELETED // destroyed at the provider (user request / teardown)
  ROTATING // old reference destroyed, new enrolment pending
}

/**
 * Duplicate identity classification (Phase 4) - explicit outcomes; only
 * LIKELY_IMPERSONATION may suspend the badge automatically.
 */
enum DuplicateIdentityClass {
  UNKNOWN // never checked / provider off
  SELF_RESTORE // matches this user's own previous account/reference
  LIKELY_DUPLICATE // same person, second account - policy question
  LIKELY_IMPERSONATION // matches another user who was there FIRST
  TWIN_RISK // high similarity + conflicting identity evidence
  FAMILY_RESEMBLANCE // mid-band similarity, plausible relatives
  LOW_CONFIDENCE // signal too weak to classify
}

enum FaceCheckDecision {
  PENDING // queued, not yet compared
  PASSED // classification acceptable for this slot (cover vs gallery)
  ALLOWED // acceptable without a match (no-face gallery photos)
  FLAGGED // needs human review
  REJECTED // photo may not be published / must be replaced
}

model ProfilePhotoVerification {
  id                   String                         @id @default(cuid())
  userId               String                         @unique
  provider             String? // face-match provider name (e.g. "mock")
  // Opaque provider-side reference handle (created from the Stripe
  // identity selfie). NEVER an embedding - deleting it at the provider
  // destroys the biometric data.
  referenceId          String?
  referenceVersion     Int                            @default(0)
  status               ProfilePhotoVerificationStatus @default(QUEUED)
  badgeStatus          FaceBadgeStatus                @default(NONE)
  riskLevel            Int                            @default(0) // aggregate mismatch score
  consentVersion       String? // biometric consent version accepted at start
  consentAt            DateTime?
  identitySessionId    String? // Stripe session the reference derives from
  lastRunAt            DateTime?
  expiresAt            DateTime? // reference re-challenge horizon
  // --- Reference lifecycle (Phase 3) ---
  referenceStatus      FaceReferenceStatus? // null = never enrolled
  providerModelVersion String? // vendor model the reference was built with
  providerRegion       String? // processing region (EU pinning evidence)
  lastValidatedAt      DateTime? // last successful use/validation of the reference
  rotationReason       String? // provider_upgrade | reference_expiry | manual_review | fraud_investigation | user_request | policy_change
  // --- Duplicate identity (Phase 4) ---
  duplicateClass       DuplicateIdentityClass         @default(UNKNOWN)
  duplicateCheckedAt   DateTime?
  /**
   * Risk band snapshot (LOW/MEDIUM/HIGH/CRITICAL) stamped at run time -
   * the admin queue reads THIS instead of recomputing per row (PRR TD-3).
   */
  riskBand             String?
  /**
   * Calibration config version active when the decision was made.
   */
  calibrationVersion   String?
  // --- Queue lease (H-2 mutual exclusion) ---
  leaseToken           String? // set on QUEUED->CLAIMED; only the holder may proceed
  leaseExpiresAt       DateTime?
  claimedBy            String? // worker/invocation id (diagnostic)
  attemptCount         Int                            @default(0)
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  checks           PhotoFaceCheck[]
  livenessSessions LivenessSession[]
  faceReferences   FaceReferenceRecord[]

  @@index([status])
  @@index([status, updatedAt])
  @@index([badgeStatus])
}

model PhotoFaceCheck {
  id                 String                  @id @default(cuid())
  verificationId     String
  userId             String
  photoId            String
  // Immutable version pin: a check is valid ONLY for this exact stored
  // image version (Photo.mediaVersion). Replaced/recropped bytes bump
  // mediaVersion and invalidate this row.
  photoVersion       Int
  isCoverAtCheck     Boolean                 @default(false)
  classification     FaceCheckClassification
  decision           FaceCheckDecision       @default(PENDING)
  faceCount          Int?
  ownerDetected      Boolean?
  // Calibration data (internal only - never shown to users): band is the
  // coarse presentation value; the raw score exists for threshold tuning.
  similarityScore    Float?
  confidenceBand     String? // "confident" | "uncertain" | "mismatch"
  qualityScore       Float?
  manipulationRisk   Float?
  failureReason      String? // reason code, e.g. "cover_other_person"
  reviewedById       String?
  reviewedAt         DateTime?
  calibrationVersion String?
  createdAt          DateTime                @default(now())

  verification ProfilePhotoVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  photo        Photo                    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, photoVersion, verificationId])
  @@index([userId, createdAt])
  @@index([decision])
}

model VerificationAuditEvent {
  id             String   @id @default(cuid())
  userId         String
  verificationId String? // ProfilePhotoVerification id when applicable
  eventType      String // enqueue | run | auto_verified | manual_review | ...
  actorType      String // "system" | "admin" | "user"
  actorId        String?
  previousStatus String?
  newStatus      String?
  reasonCode     String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

// ---------------------------------------------------------------------------
// Liveness session ownership binding (C-1). Every provider liveness session
// is persisted BEFORE the id reaches the client and is authorized by
// (sessionId + userId + environment + status) - never by UUID secrecy or
// "the user created some session". This is session-tracking, not a second
// verification workflow.
// ---------------------------------------------------------------------------

enum LivenessSessionStatus {
  CREATED
  PROCESSING
  PASSED
  FAILED
  CONSUMED // successfully linked a reference - replay returns the existing result
  EXPIRED
  INVALIDATED
}

model LivenessSession {
  id             String                @id @default(cuid())
  // Provider (AWS) session id - UNIQUE. Never authorization by itself.
  sessionId      String                @unique
  userId         String
  verificationId String // ProfilePhotoVerification.id
  provider       String
  environment    String // staging | production - a staging id cannot be used in prod
  status         LivenessSessionStatus @default(CREATED)
  attemptNumber  Int                   @default(1)
  // Opaque flow id handed to the client instead of the provider sessionId.
  flowId         String                @unique
  createdAt      DateTime              @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?
  invalidatedAt  DateTime?

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification ProfilePhotoVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Provider-reference registry (H-1/H-3). Tracks EVERY FaceId ever created
// until deletion is confirmed - so deletion is complete (not just the
// active pointer) and enrollment is a recoverable saga, not an assumed
// atomic DB+AWS transaction.
// ---------------------------------------------------------------------------

enum FaceReferenceRecordStatus {
  PENDING_PROVIDER // attempt row written BEFORE the AWS call
  PROVIDER_CREATED // AWS IndexFaces returned a FaceId (persisted immediately)
  LINKED // linked onto ProfilePhotoVerification.referenceId
  LINK_FAILED // AWS created but DB link failed - compensating deletion queued
  DELETE_PENDING // deletion requested, not yet confirmed
  DELETED // provider deletion confirmed
  DELETE_FAILED // repeated deletion failure - dead-lettered
}

model FaceReferenceRecord {
  id                String                    @id @default(cuid())
  userId            String
  verificationId    String
  referenceVersion  Int
  provider          String
  environment       String
  // Deterministic per (env, user, version) - the enrollment idempotency key.
  idempotencyKey    String                    @unique
  externalImageId   String // ExternalImageId sent to IndexFaces
  externalFaceId    String? // the exact AWS FaceId (persisted right after IndexFaces)
  status            FaceReferenceRecordStatus @default(PENDING_PROVIDER)
  livenessSessionId String?
  deleteAttempts    Int                       @default(0)
  createdAt         DateTime                  @default(now())
  linkedAt          DateTime?
  deletedAt         DateTime?

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification ProfilePhotoVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  bindings     FaceIdentityBinding[]

  @@index([userId, status])
  @@index([status])
  @@index([externalFaceId])
}

// Identity<->liveness binding evidence (Epic 1 / F1, C2). SEPARATE from
// FaceReferenceRecord on purpose: reference lifecycle and identity-binding
// lifecycle are independent facts; a reference may have MULTIPLE binding
// attempts; reference rotation requires a FRESH binding; and human + future
// automated (pluggable) methods each need independent evidence without a
// schema redesign. Stores ONLY normalized evidence - never raw images,
// biometric templates, or raw AWS/Stripe payloads. Not publicly exposed.
// INERT in F1: created/read by nothing yet.
//
// Lifecycle policy: at most ONE binding row per liveness capture
// (livenessFlowId unique); a rotation is a new capture -> new flow -> new
// binding. Multiple NULL flowIds (e.g. pre-capture human review) are allowed.
model FaceIdentityBinding {
  id                     String            @id @default(cuid())
  userId                 String
  faceReferenceId        String?
  // The Stripe Identity subject this binding is checked against (Verification
  // row id and/or the provider session id) - identifiers only, never images.
  identityVerificationId String?
  identitySessionId      String?
  livenessFlowId         String?           @unique
  method                 FaceBindingMethod
  provider               String
  status                 FaceBindingStatus @default(BINDING_REQUIRED)
  // Normalized band only (e.g. "confident"/"uncertain"/"mismatch") - NEVER a
  // raw similarity score.
  similarityBand         String?
  modelVersion           String?
  thresholdVersion       String?
  failureReasonCode      String?
  boundAt                DateTime?
  reviewedById           String?
  reviewedAt             DateTime?
  reviewReasonCode       String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  user          User                 @relation("FaceBindingSubject", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy    User?                @relation("FaceBindingReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  faceReference FaceReferenceRecord? @relation(fields: [faceReferenceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([faceReferenceId])
  @@index([status])
}

enum FaceBindingMethod {
  STRIPE_SELFIE_COMPARE // automated: Stripe identity selfie vs liveness frame
  HUMAN_REVIEW // staff compares identity evidence against the liveness frame
  PROVIDER_NATIVE // a combined identity+face provider binds the subject natively
}

enum FaceBindingStatus {
  NOT_BOUND
  BINDING_REQUIRED
  BINDING_IN_PROGRESS
  BOUND
  BINDING_FAILED
  MANUAL_REVIEW
  PROVIDER_UNAVAILABLE
  CONSENT_WITHDRAWN
}

// ---------------------------------------------------------------------------
// Support (P1.3 - Help, Safety & Contact platform). Inbound support/contact
// requests. Persisted FIRST, notified SECOND (email is best-effort); a
// request is never lost to a delivery failure. Category/status/priority are
// enums so the admin queue filters are type-safe.
// ---------------------------------------------------------------------------

enum SupportCategory {
  TECHNICAL
  ACCOUNT
  SUBSCRIPTION
  REFUND
  IDENTITY_VERIFICATION
  PHOTO_VERIFICATION
  PRIVACY
  SAFETY
  APPEAL
  BUSINESS
  PRESS
  OTHER
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model SupportRequest {
  id       String          @id @default(cuid())
  category SupportCategory
  status   SupportStatus   @default(OPEN)
  priority SupportPriority @default(NORMAL)
  name     String
  email    String
  /** Optional: the account email the request is about (may differ from the reply-to email). */
  accountEmail String?
  /** Optional user-supplied case/reference number. */
  reference    String?
  message      String  @db.Text
  /** Salted SHA-256 of the submitter IP - never a raw IP (auth/audit.ts). */
  ipHash String?
  /** Set when the submitter was signed in; null for anonymous submissions. */
  userId String?
  /** Staff-flagged spam; hidden from the default queue. */
  spam Boolean @default(false)
  /** Admin user id currently handling this request (denormalized, no FK). */
  assignedAdmin String?
  /** sha256(lowercased email + normalized message) - short-window dedupe. */
  dedupeHash String?
  /** True once the best-effort notification email was accepted by the provider. */
  emailDelivered Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  closedAt       DateTime?

  notes SupportNote[]

  @@index([status, createdAt])
  @@index([category, status])
  @@index([assignedAdmin, status])
  @@index([email, createdAt])
  @@index([dedupeHash, createdAt])
}

// Append-only staff-internal timeline for a support request: notes and
// logged replies. NEVER shown to the user (no user read model selects it).
model SupportNote {
  id        String   @id @default(cuid())
  requestId String
  /** Admin user id who wrote the note (denormalized, no FK). */
  authorId String?
  body     String   @db.Text
  createdAt DateTime @default(now())

  request SupportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}
