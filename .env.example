AWS_REKOGNITION_REGION=""
# Global AWS region; MUST agree with AWS_REKOGNITION_REGION (region-lock
# consistency check; a mismatch raises the region_mismatch alert):
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
FACE_COLLECTION_ID=""
AWS_ALLOWED_REGIONS=""
FACE_MODEL_VERSION=""
FACE_AWS_MATCH_SIMILARITY=""
FACE_AWS_MISMATCH_SIMILARITY=""
FACE_AWS_MIN_FACE_CONFIDENCE=""
FACE_REFERENCE_EPOCH=""
# SEPARATE admin credential (ops CLI / emergency purge only):
AWS_ADMIN_ACCESS_KEY_ID=""
AWS_ADMIN_SECRET_ACCESS_KEY=""

# --- Staged rollout controls (Phase 32) - all default OFF/dormant --------
# LEGAL GATE (state 3). Runtime processing in prod requires a version that
# is ALSO listed in FACE_LEGAL_APPROVED_VERSIONS. Leave BLANK until counsel
# signs off - this file NEVER grants legal approval.
FACE_LEGAL_APPROVAL_VERSION=""
FACE_LIVENESS_ENABLED=""
# ROLLOUT (state 6). 0 = dormant. A rehearsal REQUIRES this to be 0.
FACE_VERIFICATION_PERCENT=""
FACE_VERIFICATION_COUNTRY_ALLOWLIST=""
FACE_DUPLICATE_SEARCH_ENABLED=""
FACE_AUTO_SUSPEND_ENABLED=""
FACE_CALIBRATION_VERSION=""
FACE_STRIPE_BINDING_ENABLED=""
# Internal rehearsal allowlist (docs/FACE-REHEARSAL.md): comma-separated
# user IDs admitted while percent=0. Country override bypasses the country
# allowlist for these IDs only.
FACE_INTERNAL_USER_ALLOWLIST=""
FACE_INTERNAL_ALLOWLIST_COUNTRY_OVERRIDE=""
# Identity<->face binding platform (Epic 2/3). DORMANT until BOTH are set:
# the method AND a recorded legal approval version. HUMAN_REVIEW = staff
# confirm the liveness subject == the identity subject. Leave BLANK - this
# file never grants legal approval.
FACE_BINDING_METHOD=""              # "" (off) | HUMAN_REVIEW | STRIPE_COMPARE | PROVIDER_NATIVE
FACE_BINDING_LEGAL_APPROVAL_VERSION=""

# --- Rehearsal hard-gate attestations (docs/FACE-REHEARSAL.md) -----------
# Human attestations recorded as env values. They gate the rehearsal ONLY;
# they do NOT enable production. Set each to "1" ONLY when genuinely true.
# Counsel-approved legal versions (comma list). State 3 needs BOTH this AND
# FACE_LEGAL_APPROVAL_VERSION (which must be one of these). BLANK until
# counsel signs off - do not populate to "unblock" anything.
FACE_LEGAL_APPROVED_VERSIONS=""
FACE_AWS_DPA_CONFIRMED=""        # "1" once the AWS DPA is executed
FACE_CALIBRATION_APPROVED=""     # "1" once a calibration report is approved (state 4)
FACE_EMERGENCY_DISABLE_TESTED="" # "1" once the kill switch is verified
# Ops CLI knobs (scripts/): preflight legal strictness + calibration cost.
FACE_PREFLIGHT_REQUIRE_LEGAL=""  # "1" -> face:preflight FAILs without legal approval
FACE_AWS_COST_PER_CALL=""        # USD/call for calibration cost estimates (default 0.001)
# Calibration-only tooling (G3.2 - docs/CALIBRATION.md). NEVER set these in
# production: the calibration CLI (scripts/calibration.ts) refuses to run unless
# FACE_ENVIRONMENT!=production AND NODE_ENV!=production AND FACE_CALIBRATION_MODE=1
# AND a DEDICATED calibration collection (distinct from FACE_COLLECTION_ID,
# explicitly named "*calibration*") is set. Static IndexFaces enrollment is
# allowed ONLY through this gated path; production stays liveness-only.
FACE_CALIBRATION_MODE=""             # "1" enables the calibration CLI (non-prod only)
FACE_CALIBRATION_COLLECTION_ID=""    # dedicated non-prod collection, e.g. tirvea-faces-calibration-staging
# Queue scalability (Phase 27)
FACE_SWEEP_BATCH=""
FACE_SWEEP_TIME_BUDGET_MS=""
FACE_LEASE_MINUTES=""
# Session binding + registry + region (blocker remediation)
FACE_ENVIRONMENT=""
FACE_LIVENESS_TTL_MINUTES=""
FACE_REFERENCE_KEY_SECRET=""
FACE_DELETE_MAX_ATTEMPTS=""
FACE_EMERGENCY_DISABLE=""
# Browser liveness streaming via STS AssumeRole (NO Cognito) - the role
# scoped to rekognition:StartFaceLivenessSession only (docs/AWS-IAM).
FACE_LIVENESS_ROLE_ARN=""
FACE_LIVENESS_STS_TTL_SECONDS=""
