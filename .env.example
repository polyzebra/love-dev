# ============================================================================
# Virelsy - environment template
# Copy to .env and fill in. Empty values are treated as "not set" - features
# degrade gracefully (e.g. OAuth buttons hide/explain instead of breaking).
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL via Prisma)
# Local:      any reachable Postgres
# Production: Supabase -> Project Settings -> Database
#   DATABASE_URL = pooled connection string (port 6543, pgbouncer)
#   DIRECT_URL   = direct connection string (port 5432) - used by migrations
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/virelsy"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/virelsy"

# ----------------------------------------------------------------------------
# SUPABASE AUTH (authentication now lives entirely in Supabase Auth)
# Supabase Dashboard -> Project Settings -> API
#   NEXT_PUBLIC_SUPABASE_URL      = https://<project-ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = anon public key (safe for the browser)
#
# Dashboard -> Authentication -> Providers -> Google:
#   enable + paste the Google OAuth client id/secret.
#   In Google Cloud Console the ONLY redirect URI needed is Supabase's:
#     https://<project-ref>.supabase.co/auth/v1/callback
#
# Dashboard -> Authentication -> URL Configuration:
#   Site URL:      https://virelsy.com        (http://localhost:3000 in dev)
#   Redirect URLs: http://localhost:3000/auth/callback
#                  https://virelsy.com/auth/callback
#
# Apple: "Continue with Apple" is FEATURE-FLAGGED and hidden by default.
# Set NEXT_PUBLIC_APPLE_LOGIN_ENABLED="true" ONLY after BOTH are done:
#   1. Apple Developer: a Services ID with Sign in with Apple enabled, the
#      Supabase callback (https://<project-ref>.supabase.co/auth/v1/callback)
#      registered as a Return URL, and a Sign in with Apple key (.p8).
#   2. Supabase Dashboard -> Authentication -> Providers -> Apple: enabled
#      with that Services ID + the generated client-secret JWT.
# (Legacy NEXT_PUBLIC_APPLE_OAUTH=1 still shows the button; prefer the new flag.)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SERVER-ONLY (never NEXT_PUBLIC_, never imported by client components).
# Powers the auth.users.phone mirror after Twilio-approved verifications and
# the phone reconciliation service (docs/AUTH-SETUP.md section 5f). Absent =
# verifications still succeed; sync lands in a durable FAILED state instead.
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_APPLE_LOGIN_ENABLED="false"

# ----------------------------------------------------------------------------
# APPLE SIGN IN (optional - the button is hidden until configured)
# Apple Developer -> Certificates, Identifiers & Profiles
#   APPLE_ID          = the Services ID (e.g. com.virelsy.web)
#   APPLE_TEAM_ID     = 10-char team id
#   APPLE_KEY_ID      = key id of your Sign in with Apple key
#   APPLE_PRIVATE_KEY = contents of the .p8 file ("\n" for newlines is fine)
# The client-secret JWT is minted automatically from these at boot.
# Alternatively provide a pre-generated JWT directly as APPLE_SECRET.
# Return URL to register at Apple: https://virelsy.com/api/auth/callback/apple
# ----------------------------------------------------------------------------
APPLE_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_SECRET=""

# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
# Canonical site origin used to build every auth redirect (OAuth callback,
# password reset, OTP links). MUST be set in production:
#   Production: NEXT_PUBLIC_SITE_URL="https://tirvea.com"
#   Dev:        leave empty - falls back to VERCEL_URL, then the browser
#               origin, then http://localhost:3000
NEXT_PUBLIC_SITE_URL=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"   # https://virelsy.com in prod
EMAIL_FROM="Virelsy <hello@virelsy.app>"
RESEND_API_KEY=""          # email delivery (notification outbox + auth mail); absent = honest DEAD "not_configured" outbox rows
# Resend delivery webhook (Resend Dashboard -> Webhooks -> endpoint
# POST /api/webhooks/email, events email.delivered/bounced/complained).
# Svix-style signing secret ("whsec_..."); the endpoint fails CLOSED (503)
# without it and rejects bad/replayed signatures with 401. Bounces and
# complaints land on the SuppressedEmail list - those addresses are never
# emailed again.
RESEND_WEBHOOK_SECRET=""

# Payments (Stripe-first).
#   STRIPE_SECRET_KEY               sk_test_/sk_live_ - server-only
#   STRIPE_WEBHOOK_SECRET           whsec_ signing secret of the webhook
#                                   endpoint {SITE}/api/webhooks/stripe
#   STRIPE_*_MONTHLY_PRICE_ID       recurring EUR monthly prices created in
#                                   the Stripe dashboard: Plus 14.99, Gold
#                                   29.99. Must match the key's mode; the
#                                   two ids must differ. Server-only - the
#                                   browser never sees or supplies these.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PLUS_MONTHLY_PRICE_ID=""
STRIPE_GOLD_MONTHLY_PRICE_ID=""

# Seed (dev fixtures)
SEED_ADMIN_PASSWORD="admin-virelsy-2026"

# Auth webhook (Supabase Database Webhook on auth.users -> /api/webhooks/supabase-auth)
SUPABASE_WEBHOOK_SECRET=""

# Cron auth (Vercel Cron -> GET /api/cron/auth-cleanup). Any long random
# string; Vercel sends it as "Authorization: Bearer <CRON_SECRET>". The
# route fails closed when unset. See docs/AUTH-SETUP.md "Pending auth users".
CRON_SECRET=""

# ----------------------------------------------------------------------------
# ADMIN BOOTSTRAP (one-time SUPER_ADMIN promotion - docs/ADMIN-SETUP.md)
# BOTH server-only (never NEXT_PUBLIC_). The email is the account that will
# be promoted; the secret authorizes POST /api/admin/bootstrap (header
# x-bootstrap-secret). Generate the secret with: openssl rand -hex 32
# The mechanism self-disables once a SUPER_ADMIN exists (410) - the vars
# can (and should) be removed after the promotion succeeds.
# ----------------------------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL="info@tirvea.com"
ADMIN_BOOTSTRAP_SECRET=""

# ----------------------------------------------------------------------------
# AUTH HARDENING
# ----------------------------------------------------------------------------
# Server-side salt for hashing IP addresses / user agents in the auth audit
# trail (AuthVerificationEvent). Any long random string. REQUIRED in prod -
# without it a dev-only constant is used and a warning is logged.
AUTH_HASH_SALT=""

# Phone verification - provider selection (see src/lib/auth/phone.ts):
#   1. Twilio Verify: used when ALL THREE TWILIO_* vars below are set.
#      Twilio Verify owns the codes and their expiry (10 min service
#      default) - we never generate or store OTP codes ourselves.
#   2. Supabase Phone Auth: used when SUPABASE_PHONE_ENABLED="true" (and
#      Twilio is not fully configured). Requires an SMS provider wired up
#      in the Supabase dashboard.
#   3. Neither: the phone step is skipped entirely - we never demand a
#      phone number we cannot verify.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""
SUPABASE_PHONE_ENABLED="false"

# Phone LOGIN (anonymous sign-in via native Supabase phone OTP) - a
# SEPARATE feature from the phone-change verification above. Flip to
# "true" ONLY after the Supabase dashboard has (1) the Phone sign-in
# provider ENABLED and (2) Twilio Verify configured as its SMS provider
# (docs/AUTH-SETUP.md "Phone login"). While "false" the
# /api/auth/phone-login/* routes answer 503 PHONE_LOGIN_NOT_AVAILABLE and
# the UI must hide the button. The flag also arms the auth.users.phone
# backfill on successful phone-change verifies.
PHONE_LOGIN_ENABLED="false"
# Phone country support (ISO-3166 alpha-2, comma-separated) - parsed
# ONLY by src/lib/auth/phone-countries.ts (getSupportedPhoneCountries).
# SUPPORTED_PHONE_COUNTRIES is THE one shared base for EVERY phone
# workflow (login, verification, change). Unset (the default) = every
# country in the shared dataset - the SMS capability is Twilio Verify,
# which delivers worldwide - so set it only to narrow the whole product.
# Unknown codes are dropped; the first entry is the UI's default country
# (the full-dataset default is alphabetical and the UI prefers IE).
# SUPPORTED_PHONE_COUNTRIES=""
# Per-workflow overrides NARROW the base, never widen it: when set, the
# workflow resolves to intersection(base, override) - codes outside the
# base are dropped, and an override that intersects to nothing is
# ignored. Leave these unset so every workflow shows the same full list;
# set one ONLY with a documented legal/provider reason (e.g. an SMS
# compliance restriction on anonymous login in a specific region).
# The /auth/phone verification step and the settings phone change share
# one flow, which enforces the "change" list.
# PHONE_LOGIN_COUNTRIES=""
# PHONE_VERIFICATION_COUNTRIES=""
# PHONE_CHANGE_COUNTRIES=""

# Email OTP length - must MATCH Supabase dashboard (Authentication ->
# Email -> "Email OTP Length"). Default 6; this project's dashboard is
# currently set to 8, so production needs 8 here until the dashboard
# is changed to 6 (recommended).
NEXT_PUBLIC_EMAIL_OTP_LENGTH=6

# ----------------------------------------------------------------------------
# TOOLING (dev only - never read by the app at runtime)
# ----------------------------------------------------------------------------
# 21st.dev Magic MCP server (see .mcp.json). Get your key from
# https://21st.dev/magic/console - the MCP server cannot function
# without it.
TWENTYFIRST_API_KEY=""

# ----------------------------------------------------------------------------
# TRUST & SAFETY
# ----------------------------------------------------------------------------
# Photo moderation provider selection (src/lib/services/moderation.ts):
#   1. "mock" in MODERATION_PROVIDER -> deterministic MockModerationProvider
#      (dev/tests). Optional MOCK_MODERATION_SCORES holds a JSON object of
#      scores it returns for every upload, e.g.
#      {"adultScore":0.9,"confidence":0.95} - tests set scores in-process
#      via setMockModerationConfig().
#   2. MODERATION_API_URL + MODERATION_API_KEY -> external provider
#      (posts card-variant bytes; maps adultScore/violenceScore/
#      minorRiskScore/aiGeneratedScore/duplicateMatchScore/
#      reverseImageRisk/confidence when returned).
#   3. Neither -> honest null provider: photos auto-approve labelled
#      "unmoderated" (dev-friendly, loudly logged).
#   4. MODERATION_PROVIDERS (ordered comma list, takes precedence over 2)
#      -> real-provider fallback chain, e.g. "openai,google_vision,hive,external".
#      Each name needs its key below or it is skipped; every provider gets
#      MODERATION_TIMEOUT_MS (default 8000) via AbortSignal; on failure the
#      chain moves on; when ALL fail the photo lands in needs_review with a
#      FAILED PhotoModerationResult - never auto-approved. Health per
#      provider is tracked in ProviderHealth (admin /api/admin/safety/providers).
#      Adapters:
#        openai        -> OPENAI_API_KEY (omni-moderation-latest, REST)
#        google_vision -> GOOGLE_VISION_API_KEY (SafeSearch + face detection)
#        hive          -> HIVE_API_KEY (v2 sync visual moderation)
#        external      -> the generic MODERATION_API_URL/KEY adapter
#        aws_rekognition / azure -> documented stubs (need SigV4/SDK; see
#        src/lib/services/moderation-providers.ts for env names + mapping)
MODERATION_PROVIDER=""
MODERATION_PROVIDERS=""
MODERATION_TIMEOUT_MS=""
OPENAI_API_KEY=""
GOOGLE_VISION_API_KEY=""
HIVE_API_KEY=""
MOCK_MODERATION_SCORES=""
MODERATION_API_URL=""
MODERATION_API_KEY=""

# IP intelligence (VPN/TOR/ASN/geo) for the login risk engine + fraud
# signals. IP_INTEL_PROVIDER = "ipqs" (default) | "ipinfo"; without the key
# the engine keeps recording 'ip-intel:unavailable' honestly and the
# signals contribute zero. Raw IPs are passed transiently, never stored.
IP_INTEL_API_KEY=""
IP_INTEL_PROVIDER=""

# Extra disposable-email domains (comma list) merged into the curated
# blocklist in src/lib/auth/disposable-domains.ts at call time.
DISPOSABLE_EMAIL_DOMAINS=""

# Appeal evidence attachments are DESIGNED BUT NOT ENABLED (honest 501 from
# POST /api/appeals/[id]/attachments). Design notes live in
# src/lib/services/appeals.ts (appealAttachmentsEnabled). Flipping this on
# without shipping the upload pipeline still answers 501 - nothing fakes.
APPEAL_ATTACHMENTS_ENABLED="false"

# --- Photo verification -------------------------------------------------
# IMPORTANT: one key = ONE line in any env file. Loaders disagree on
# duplicates (Next.js keeps the LAST value; dotenv/tsx/Prisma keep the
# FIRST), so a duplicated key silently runs different values in
# different tools. Overrides belong in the PROCESS env (npm scripts),
# which every loader respects.
#
# VERIFICATION_PROVIDER = "mock" | "stripe_identity" | "persona"
#   - LOCAL DEFAULT: mock (full state machine, HMAC-SHA256-signed
#     webhooks against VERIFICATION_WEBHOOK_SECRET via
#     POST /api/webhooks/verification; refused in production builds).
#   - LOCAL LIVE (explicit opt-in only): `npm run dev:live` - sets
#     VERIFICATION_PROVIDER=stripe_identity + ALLOW_LIVE_VERIFICATION=1
#     as process env. A LIVE key (sk_live_) outside production is
#     REFUSED without that flag: real sessions bill real money.
#   - PRODUCTION (Vercel env, never this file): all three of
#     VERIFICATION_PROVIDER=stripe_identity, STRIPE_SECRET_KEY (shared
#     with billing) and STRIPE_IDENTITY_WEBHOOK_SECRET (DEDICATED
#     Identity endpoint secret - never the billing webhook secret;
#     endpoint https://tirvea.com/api/webhooks/verification). Partial
#     config stays honestly unavailable (503).
#   - persona requires PERSONA_API_KEY (+ PERSONA_TEMPLATE_ID);
#     PERSONA_WEBHOOK_SECRET will verify its webhooks. Adapter not
#     implemented yet - refuses honestly.
VERIFICATION_PROVIDER="mock"
VERIFICATION_WEBHOOK_SECRET=""
STRIPE_IDENTITY_WEBHOOK_SECRET=""
PERSONA_API_KEY=""
PERSONA_TEMPLATE_ID=""
PERSONA_WEBHOOK_SECRET=""

# --- Profile-photo verification (face match layer) -----------------------
# SEPARATE from identity verification: Stripe proves the person; this
# layer proves the GALLERY belongs to them (docs/FACE-VERIFICATION.md).
# Dormant while unset - badge derives from identity alone. "mock" is
# dev/tests only (refused in production builds). Thresholds are
# PER-PROVIDER calibrations - tune against real samples before go-live.
#
# SIX INDEPENDENT LIFECYCLE STATES (docs/FACE-VERIFICATION-RUNBOOK.md, top).
# These are SEPARATE - satisfying one does NOT imply the next:
#   1 implemented      code exists (compile-time; no flag) ........... DONE
#   2 configured       FACE_MATCH_PROVIDER set .................. per-env, OFF in prod
#   3 legally approved FACE_LEGAL_APPROVAL_VERSION in FACE_LEGAL_APPROVED_VERSIONS
#                      (counsel sign-off - NOT granted here) ......... PENDING
#   4 calibrated       FACE_CALIBRATION_APPROVED=1 + a threshold version  PENDING
#   5 rehearsed        all 8 rehearsal gates pass (docs/FACE-REHEARSAL.md) PENDING
#   6 rolled out       FACE_VERIFICATION_PERCENT > 0 ................... 0 (dormant)
# Leave prod at state 1: provider unset, no legal version, percent 0.
FACE_MATCH_PROVIDER=""
FACE_MATCH_THRESHOLD=""
FACE_MISMATCH_THRESHOLD=""
FACE_MIN_QUALITY=""
FACE_MANIPULATION_THRESHOLD=""
# Preferred alias for the manipulation cutoff (falls back to the name above):
FACE_MANIPULATION_RISK_THRESHOLD=""
# Lower bound of the manual-review score band (default: FACE_MISMATCH_THRESHOLD):
FACE_MANUAL_REVIEW_MIN=""
# Threshold calibration label (default "v0"); also a calibration-gate source:
FACE_THRESHOLD_VERSION=""
FACE_COVER_MIN_DOMINANCE=""
FACE_MAX_OTHER_PERSON_PHOTOS=""
FACE_REFERENCE_TTL_DAYS=""
FACE_REFERENCE_RENEWAL_WINDOW_DAYS=""
# Risk engine (docs/THREAT-MODEL-VERIFICATION.md): band boundaries +
# face-signal weights; every threshold is config-driven.
RISK_MEDIUM_AT=""
RISK_HIGH_AT=""
RISK_CRITICAL_AT=""
# Provider resilience (docs/FACE-VERIFICATION-RUNBOOK.md): breaker,
# backoff, dead-letter + alert thresholds.
PROVIDER_DEGRADED_AT=""
PROVIDER_UNAVAILABLE_AT=""
PROVIDER_BREAKER_COOLDOWN_MS=""
PROVIDER_ERROR_TTL_MS=""
PROVIDER_RETRIES=""
PROVIDER_BACKOFF_BASE_MS=""
PROVIDER_TIMEOUT_MS=""
FACE_DEAD_LETTER_ERRORS=""
ALERT_QUEUE_STALL_MINUTES=""
ALERT_VERIFICATION_SPIKE=""
ALERT_APPEAL_SPIKE=""
ALERT_FALSE_POSITIVE_PCT=""
# Rule thresholds added with the alert rules (docs/FACE-ALERTING.md):
ALERT_DLQ_MAX=""            # DLQ depth that fires face_dead_letter (default 0)
ALERT_SUSPENSION_MAX=""     # suspensions/24h that fire suspension_spike (default 25)
ALERT_MANUAL_REVIEW_PCT=""  # manual-review %% that fires manual_review_spike (default 40)
# External operational alert channel (Phase 26) - webhook INDEPENDENT of
# the notification outbox (Slack/Discord/PagerDuty/Opsgenie). Setting this
# satisfies the rehearsal "alert channel active" gate.
ALERT_WEBHOOK_URL=""

# --- AWS Rekognition (real face provider - docs/AWS-IAM-VERIFICATION.md) --
